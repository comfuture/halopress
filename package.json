{
  "name": "halopress",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:backfill:content-listing": "tsx scripts/backfill-content-listing.ts",
    "db:drop": "drizzle-kit drop",
    "db:d1:list": "wrangler d1 migrations list DB",
    "db:d1:apply": "wrangler d1 migrations apply DB",
    "db:d1:apply:local": "wrangler d1 migrations apply DB --local",
    "db:d1:apply:remote": "wrangler d1 migrations apply DB --remote",
    "deploy": "bash scripts/deploy-cloudflare.sh",
    "deploy:cf": "bash scripts/deploy-cloudflare.sh",
    "test:deploy": "vitest run tests/cloudflare-deploy.test.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.117",
    "@iconify-json/simple-icons": "^1.2.90",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@sidebase/nuxt-auth": "1.3.1",
    "@tiptap/core": "3.27.3",
    "@tiptap/extension-collaboration": "3.27.3",
    "@tiptap/extension-drag-handle": "3.27.3",
    "@tiptap/extension-drag-handle-vue-3": "3.27.3",
    "@tiptap/extension-horizontal-rule": "3.27.3",
    "@tiptap/extension-image": "3.27.3",
    "@tiptap/extension-mention": "3.27.3",
    "@tiptap/extension-node-range": "3.27.3",
    "@tiptap/extension-placeholder": "3.27.3",
    "@tiptap/extension-text-align": "3.27.3",
    "@tiptap/extensions": "3.27.3",
    "@tiptap/markdown": "3.27.3",
    "@tiptap/pm": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "@tiptap/suggestion": "3.27.3",
    "@tiptap/vue-3": "3.27.3",
    "@tiptap/y-tiptap": "3.0.6",
    "canvas-confetti": "^1.9.4",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next-auth": "4.24.14",
    "nuxt": "^4.4.8",
    "sortablejs": "^1.15.7",
    "ulid": "^3.0.2",
    "zod": "^4.4.3",
    "zod-from-json-schema": "^0.5.4"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@nuxt/eslint": "^1.15.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.1.0",
    "@types/sortablejs": "^1.15.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "jsonc-parser": "3.3.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "4.110.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@sidebase/nuxt-auth@1.3.1>next-auth": "4.24.14"
      }
    },
    "overrides": {
      "@tiptap/*": "3.27.3",
      "@tiptap/vue-3": "3.27.3",
      "@tiptap/core": "3.27.3",
      "@tiptap/pm": "3.27.3",
      "@tiptap/extension-drag-handle-vue-3": "3.27.3",
      "@tiptap/extension-bubble-menu": "3.27.3",
      "@tiptap/extension-floating-menu": "3.27.3",
      "@tiptap/extension-list": "3.27.3",
      "@tiptap/extension-placeholder": "3.27.3",
      "@tiptap/markdown": "3.27.3",
      "@tiptap/y-tiptap": "3.0.6",
      "next-auth@4.24.14>next": "-",
      "next-auth@4.24.14>react": "-",
      "next-auth@4.24.14>react-dom": "-"
    },
    "patchedDependencies": {
      "next-auth@4.24.14": "patches/next-auth@4.24.14.patch"
    }
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "Stores all Halopress content and installation state. Create a new isolated D1 database for each site; reuse one only when redeploying that same site."
      },
      "CONTENT_ASSETS": {
        "description": "Stores uploaded media. Create a new isolated R2 bucket for each site; reuse one only when redeploying that same site."
      }
    }
  },
  "packageManager": "pnpm@10.23.0"
}
